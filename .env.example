# ============================================================
# Degen Scanner — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Telegram API credentials ---
# Get from https://my.telegram.org → API Development Tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# --- Bot Token ---
# Create a bot via @BotFather on Telegram → /newbot
BOT_TOKEN=your_bot_token_here

# --- Group IDs ---
# To get group ID: add @userinfobot to the group, or use Telethon
# Must be a negative number (e.g., -1001234567890)

# Source group: where CEX withdrawal bot posts notifications (e.g., Ray Onyx Wallet Tracker)
SOURCE_GROUP_ID=-1001234567890

# Alert group: where Degen Scanner sends cluster alerts
ALERT_GROUP_ID=-1001234567891

# Whale group (optional): source for large withdrawals (>12 SOL)
# Set to 0 to disable whale pipeline
WHALE_GROUP_ID=0

# --- Helius API (optional) ---
# Required for whale splitter to check on-chain transfers
# Free tier: https://helius.dev
# Multiple keys supported (comma-separated) — rotates on rate limit
HELIUS_API_KEYS=key1,key2,key3

# --- Clustering Settings ---
# Time window for grouping transfers into clusters (minutes)
TIME_WINDOW_MINUTES=15

# Minimum wallets to trigger a cluster alert
MIN_CLUSTER_SIZE=2

# --- Scan Interval ---
# How often to auto-scan for new messages (minutes)
SCAN_INTERVAL_MINUTES=30

# --- Session ---
# Telethon session file name (no extension)
SESSION_NAME=degen_scanner

# --- Custom Pattern Rules ---
# Path to custom rules JSON file (default: data/custom_rules.json)
# CUSTOM_RULES_FILE=data/custom_rules.json

# --- Admin ---
# Comma-separated Telegram user IDs for superadmin access
# Group admins are auto-detected; this is a fallback
# Get your ID: send /start to @userinfobot
ADMIN_IDS=

# --- Pump Scanner (Dev Tracer Bot) ---
# Optional: separate bot for /devtrace, /teach, /discuss commands
# If not set, uses BOT_TOKEN above
# PUMP_BOT_TOKEN=your_pump_bot_token_here

# Chat ID where pump scanner sends alerts
# PUMP_ALERT_CHAT_ID=-1001234567893

# Chat ID where dev trace results are sent (can be same as PUMP_ALERT_CHAT_ID)
# DEV_ALERT_CHAT_ID=-1001234567893

# --- Moralis API (optional) ---
# Token discovery — https://moralis.io
# Multiple keys supported (comma-separated)
# MORALIS_API_KEYS=key1,key2

# --- Free RPC Providers (optional, supplement Helius) ---
# SHYFT_API_KEY=your_shyft_key
# ALCHEMY_API_KEY=your_alchemy_key
# ANKR_API_KEY=your_ankr_key
# CHAINSTACK_API_KEY=your_chainstack_key
# BIRDEYE_API_KEY=your_birdeye_key

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
